{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    ".claude/skills/motioncanvas/snippets/**/*.ts",
    ".claude/skills/motioncanvas/snippets/**/*.tsx",
    ".claude/skills/motioncanvas/providers/**/*.ts",
    ".claude/skills/motioncanvas/examples/**/*.ts",
    ".claude/skills/motioncanvas/examples/**/*.tsx",
    ".claude/skills/motioncanvas/analysis/**/*.ts"
  ]
}
